# ─────────────────────────────────────────────────────────────────────
# Supabase — get from https://supabase.com/dashboard/project/<ref>/settings/api
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser. Used by admin-side CRUD / Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────
# ML service (FastAPI, apps/ml)
# ─────────────────────────────────────────────────────────────────────
# Locally: http://localhost:8000. Production: your Railway URL.
ML_SERVICE_URL=http://localhost:8000
# Shared secret sent as X-API-Key. Must match ML_API_KEY on the server.
ML_SERVICE_API_KEY=
# When true, service boots with a stub classifier if weights are missing.
# Keep true until Day 2 fine-tune is uploaded; flip to false after.
ML_ALLOW_STUB=true

# ─────────────────────────────────────────────────────────────────────
# Maps — https://cloud.maptiler.com/account/keys/
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPTILER_KEY=

# ─────────────────────────────────────────────────────────────────────
# Push notifications — https://onesignal.com/
# ─────────────────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─────────────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────────────
# Slug of the default community (residents see / dispatchers manage this one).
NEXT_PUBLIC_DEFAULT_COMMUNITY_SLUG=pryluky
